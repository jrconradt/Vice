#nullable enable
using System;

namespace MyApp;

internal static class ViceComposition
{
    internal static global::Vice.Host.ViceAppBuilder ComposeFromAttributes(this global::Vice.Host.ViceAppBuilder builder, global::MyApp.HostServices host)
    {
        if (builder is null)
        {
            throw new global::System.ArgumentNullException(nameof(builder));
        }
        if (host is null)
        {
            throw new global::System.ArgumentNullException(nameof(host));
        }
        builder.WithSessionService<global::MyApp.IMyService>(global::MyApp.Factories.BuildSvc(host.Svc));
        return builder;
    }

    internal static global::Vice.Core.IViceApp RegisterDiscoveredPacks(this global::Vice.Core.IViceApp app, global::MyApp.HostServices host)
    {
        if (app is null)
        {
            throw new global::System.ArgumentNullException(nameof(app));
        }
        if (host is null)
        {
            throw new global::System.ArgumentNullException(nameof(host));
        }
        return app;
    }
}

#compdef vice
# zsh completion for vice
# install: vice completions zsh > "${fpath[1]}/_vice"
# or for the current shell: source <(vice completions zsh)

_vice() {
    local cur="${words[CURRENT]}"

    if [[ "$cur" == --* ]]; then
        local -a globals
        globals=(
            '--chunk-size=[Byte-stream chunk size in bytes]'
            '--color=[Force or suppress color output (auto|always|never)]'
            '--depth=[Maximum recursion depth]'
            '--dry-run[Show what would happen without making changes]'
            '--encoding=[Text encoding (utf8|ascii)]'
            '--format=[Output or content format (text|hex|json|...)]'
            '--help[Show help]'
            '--limit=[Maximum results to return]'
            '--locale=[BCP-47 locale tag for output formatting (e.g. en-US, de-DE)]'
            '--metadata=[Per-call metadata as JSON]'
            '--no-color[Disable ANSI color output]'
            '--no-pager[Disable PAGER wrapping for long output]'
            '--no-status[Disable status spinner]'
            '--non-interactive[Refuse to prompt; fail fast on missing input]'
            '--offset=[Skip this many results]'
            '--page=[1-based page number (alternative to offset)]'
            '--quiet[Suppress non-error output]'
            '--timeout=[Maximum I/O wait time in milliseconds]'
            '--verbose[Verbose output]'
            '--version[Show version]'
        )
        _describe -t globals 'option' globals
        return
    fi

    local state="root"
    local skip=0
    local i=2
    while (( i < CURRENT )); do
        local word="${words[i]}"
        if (( skip > 0 )); then
            skip=$((skip-1))
            i=$((i+1))
            continue
        fi
        case "$state:$word" in
            "root:alpha"|"root:a") state="root__alpha"; ;;
            "root:beta") state="root__beta"; ;;
            "root:cancel") state="root__cancel"; skip=1; ;;
            "root:clear") state="root__clear"; ;;
            "root:completions") state="root__completions"; skip=1; ;;
            "root:daemon") state="root__daemon"; ;;
            "root:exit"|"root:quit") state="root__exit"; ;;
            "root:gamma") state="root__gamma"; ;;
            "root:help") state="root__help"; skip=1; ;;
            "root:history") state="root__history"; ;;
            "root:jobs") state="root__jobs"; ;;
            "root:list") state="root__list"; ;;
            "root:manpage") state="root__manpage"; ;;
            "root:pause") state="root__pause"; skip=1; ;;
            "root:resume") state="root__resume"; skip=1; ;;
            "root:status") state="root__status"; ;;
            "root:version") state="root__version"; ;;
            "root__beta:things") state="root__beta__things"; skip=1; ;;
            "root__list:commands") state="root__list__commands"; ;;
            *) state="unknown" ;;
        esac
        i=$((i+1))
    done

    if (( skip > 0 )); then
        _files
        return
    fi

    case "$state" in
        "root")
            local -a candidates
            candidates=(
                'alpha:alpha description'
                'a:alpha description'
                'beta:beta description'
                'cancel:Cancel a background job'
                'clear:Clear the screen'
                'completions:Emit a shell completion script (bash | zsh) to stdout.'
                'daemon:Run as a background daemon to keep async jobs alive.'
                'exit:Exit the session'
                'quit:Exit the session'
                'gamma:gamma description'
                'help:Show help'
                'history:Show command history'
                'jobs:List background jobs'
                'list:List all commands'
                'manpage:Emit a groff(7) man page for this tool to stdout.'
                'pause:Pause a background job'
                'resume:Resume a paused job'
                'status:Query a running daemon for job status (if any).'
                'version:Show version'
            )
            _describe -t verb 'verb' candidates
            ;;
        "root__beta")
            local -a candidates
            candidates=(
                'things:beta description'
            )
            _describe -t subcommand 'subcommand' candidates
            ;;
        "root__list")
            local -a candidates
            candidates=(
                'commands:List all commands'
            )
            _describe -t subcommand 'subcommand' candidates
            ;;
        *) _files ;;
    esac
}

compdef _vice vice


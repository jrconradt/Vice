# bash completion for vice
# install: vice completions bash > ~/.local/share/bash-completion/completions/vice
# or for the current shell: source <(vice completions bash)

_vice() {
    local cur="${COMP_WORDS[COMP_CWORD]}"

    if [[ "$cur" == --* ]]; then
        COMPREPLY=( $(compgen -W "--chunk-size --color --depth --dry-run --encoding --format --help --limit --locale --metadata --no-color --no-pager --no-status --non-interactive --offset --page --quiet --timeout --verbose --version" -- "$cur") )
        return 0
    fi

    local state="root"
    local skip=0
    local i=1
    while (( i < COMP_CWORD )); do
        local word="${COMP_WORDS[$i]}"
        if (( skip > 0 )); then
            skip=$((skip-1))
            i=$((i+1))
            continue
        fi
        case "$state:$word" in
            "root:alpha"|"root:a") state="root__alpha"; ;;
            "root:beta") state="root__beta"; ;;
            "root:cancel") state="root__cancel"; skip=1; ;;
            "root:clear") state="root__clear"; ;;
            "root:completions") state="root__completions"; skip=1; ;;
            "root:daemon") state="root__daemon"; ;;
            "root:exit"|"root:quit") state="root__exit"; ;;
            "root:gamma") state="root__gamma"; ;;
            "root:help") state="root__help"; skip=1; ;;
            "root:history") state="root__history"; ;;
            "root:job") state="root__job"; ;;
            "root:jobs") state="root__jobs"; ;;
            "root:list") state="root__list"; ;;
            "root:manpage") state="root__manpage"; ;;
            "root:status") state="root__status"; ;;
            "root:version") state="root__version"; ;;
            "root__beta:things") state="root__beta__things"; skip=1; ;;
            "root__job:run") state="root__job__run"; skip=1; ;;
            "root__list:commands") state="root__list__commands"; ;;
            *) state="unknown" ;;
        esac
        i=$((i+1))
    done

    if (( skip > 0 )); then
        COMPREPLY=( $(compgen -f -- "$cur") )
        return 0
    fi

    case "$state" in
        "root") COMPREPLY=( $(compgen -W "alpha a beta cancel clear completions daemon exit quit gamma help history job jobs list manpage status version" -- "$cur") ) ;;
        "root__beta") COMPREPLY=( $(compgen -W "things" -- "$cur") ) ;;
        "root__job") COMPREPLY=( $(compgen -W "run" -- "$cur") ) ;;
        "root__list") COMPREPLY=( $(compgen -W "commands" -- "$cur") ) ;;
        *) COMPREPLY=( $(compgen -f -- "$cur") ) ;;
    esac
    return 0
}

complete -F _vice vice

